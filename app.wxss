page {
  --primary: #d43c33;
  --background: #f5f5f5;
  --card-background: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --border: #e5e5e5;
  --blur-overlay: rgba(255, 255, 255, 0.8);
}

page.dark {
  --primary: #d43c33;
  --background: #1a1a1a;
  --card-background: #2a2a2a;
  --text: #ffffff;
  --text-secondary: #999999;
  --border: #3a3a3a;
  --blur-overlay: rgba(0, 0, 0, 0.6);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background-color: var(--background);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  background-color: var(--background);
}

.card {
  background-color: var(--card-background);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: var(--primary);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  padding: 0;
}

.icon-btn::after {
  border: none;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
