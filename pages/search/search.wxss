.search-page {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 130rpx;
}

.search-header {
  padding: 30rpx;
  background: var(--card-background);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--background);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.search-input::placeholder {
  color: var(--text-secondary);
}

.clear-btn {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.5;
}

.hot-search {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.hot-tag {
  padding: 16rpx 30rpx;
  background: var(--card-background);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: var(--text);
}

.hot-tag:nth-child(1),
.hot-tag:nth-child(2),
.hot-tag:nth-child(3) {
  color: var(--primary);
}

.search-results {
  padding: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.result-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.result-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-artist {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.play-btn-small {
  width: 60rpx;
  height: 60rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.history-section {
  padding: 30rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--card-background);
  border-radius: 16rpx;
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.clear-history {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 30rpx;
}
