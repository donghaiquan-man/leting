.player-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景毛玻璃 */
.bg-blur {
  position: fixed;
  top: -50rpx;
  left: -50rpx;
  right: -50rpx;
  bottom: -50rpx;
  filter: blur(80rpx) brightness(0.4);
  z-index: -1;
}

/* 顶部导航 */
.player-nav {
  display: flex;
  align-items: center;
  padding: 60rpx 32rpx 20rpx;
}

.nav-back, .nav-share {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  overflow: hidden;
}

.song-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artist-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

/* 主区域 */
.main-area {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}

.album-container {
  width: 540rpx;
  height: 540rpx;
  transition: opacity 0.3s;
}

.album-container.hidden {
  opacity: 0;
  position: absolute;
}

.album-cover {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.4);
}

.lyrics-container {
  width: 100%;
  height: 100%;
  transition: opacity 0.3s;
}

.lyrics-container.hidden {
  opacity: 0;
  position: absolute;
}

/* 功能按钮行 */
.action-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 30rpx 0;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.active {
  color: var(--primary);
}

/* 进度条 */
.progress-section {
  padding: 20rpx 60rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 4rpx;
  position: relative;
  transition: width 0.1s linear;
}

.progress-fill::after {
  content: '';
  position: absolute;
  right: -14rpx;
  top: -10rpx;
  width: 28rpx;
  height: 28rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.time-display {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 播放控制 */
.play-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  padding: 30rpx 0;
}

.mode-btn, .sleep-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.15) !important;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-sheet {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(40rpx);
  border-radius: 40rpx 40rpx 0 0;
  padding: 50rpx 40rpx 80rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40rpx;
}

.mode-grid {
  display: flex;
  justify-content: space-around;
}

.mode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.mode-item.active {
  opacity: 1;
}

.mode-item text {
  font-size: 24rpx;
  color: #ffffff;
}

.sleep-timer {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40rpx;
}

.sleep-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.sleep-option {
  padding: 20rpx 36rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #ffffff;
}
