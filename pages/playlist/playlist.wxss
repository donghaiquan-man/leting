.playlist-page {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 130rpx;
}

.header {
  padding: 40rpx 30rpx;
  background: var(--primary);
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
}

.header-info {
  font-size: 24rpx;
  margin-top: 12rpx;
  opacity: 0.8;
}

.header-actions {
  display: flex;
  gap: 30rpx;
  margin-top: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
}

.song-list {
  padding: 20rpx;
}

.song-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-background);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.song-item.playing {
  background: linear-gradient(135deg, var(--primary) 0%, rgba(212, 60, 51, 0.8) 100%);
}

.song-item.playing .song-name,
.song-item.playing .artist-name {
  color: #ffffff;
}

.song-index {
  width: 60rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  flex-shrink: 0;
}

.song-item.playing .song-index {
  color: #ffffff;
}

.playing-indicator {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 32rpx;
  gap: 4rpx;
}

.playing-bar {
  width: 6rpx;
  background: #ffffff;
  border-radius: 3rpx;
  animation: playing 0.8s ease-in-out infinite;
}

.playing-bar:nth-child(1) { height: 12rpx; animation-delay: 0s; }
.playing-bar:nth-child(2) { height: 20rpx; animation-delay: 0.2s; }
.playing-bar:nth-child(3) { height: 16rpx; animation-delay: 0.4s; }

@keyframes playing {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.5); }
}

.song-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.song-details {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.song-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artist-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-actions {
  display: flex;
  gap: 20rpx;
  padding-left: 20rpx;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  padding: 10rpx;
  opacity: 0.6;
}

.delete-btn {
  color: #ff4d4f;
}

/* 拖拽排序样式 */
.song-item.dragging {
  opacity: 0.8;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 30rpx;
}
