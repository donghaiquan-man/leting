<view class="index-page">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="header-title">乐听</view>
    <view class="header-actions">
      <view class="theme-btn" bindtap="toggleTheme">
        <image 
          src="{{isDarkMode ? '/static/icons/sun.png' : '/static/icons/moon.png'}}" 
          mode="aspectFit" 
          style="width:36rpx;height:36rpx;filter:{{isDarkMode?'none':'invert(1)'}}" 
        />
      </view>
    </view>
  </view>

  <!-- 歌曲列表 -->
  <view class="song-list">
    <view 
      wx:for="{{songs}}" 
      wx:key="id"
      class="song-item {{item.id === currentSong.id ? 'playing' : ''}}"
      data-index="{{index}}"
      bindtap="onSongTap"
    >
      <!-- 序号 -->
      <view class="song-index {{item.id === currentSong.id ? 'playing' : ''}}">
        <text wx:if="{{item.id !== currentSong.id}}" class="index-text">{{index + 1}}</text>
        <image 
          wx:else 
          src="/static/icons/play.png" 
          mode="aspectFit" 
          class="playing-icon"
          style="width:32rpx;height:32rpx;filter:invert(1)" 
        />
      </view>

      <!-- 封面 -->
      <image class="song-cover" src="{{item.cover}}" mode="aspectFill" />

      <!-- 歌曲信息 -->
      <view class="song-info">
        <view class="song-name {{item.id === currentSong.id ? 'playing' : ''}}">{{item.name}}</view>
        <view class="song-artist">{{item.artist}}</view>
      </view>

      <!-- 收藏按钮 -->
      <view class="song-action" data-index="{{index}}" catchtap="toggleFavorite">
        <image 
          src="{{item.isFavorite ? '/static/icons/heart-filled.png' : '/static/icons/heart.png'}}" 
          mode="aspectFit" 
          style="width:36rpx;height:36rpx;opacity:{{item.isFavorite?1:0.4}}" 
        />
      </view>
    </view>
  </view>

  <!-- 迷你播放条 -->
  <player-bar 
    wx:if="{{currentSong}}"
    song="{{currentSong}}"
    isPlaying="{{isPlaying}}"
    progress="{{progress}}"
    bind:play="onPlayTap"
    bind:prev="onPrevTap"
    bind:next="onNextTap"
  />
</view>
