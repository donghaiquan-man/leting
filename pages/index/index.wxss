.index-page {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 130rpx;
}

/* 顶部区域 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx 20rpx;
  background: var(--card-background);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.theme-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--background);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 歌曲列表 */
.song-list {
  padding: 16rpx 0;
}

.song-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  transition: background 0.2s;
}

.song-item:active {
  background: var(--card-background);
}

.song-item.playing {
  background: var(--card-background);
}

/* 序号 */
.song-index {
  width: 56rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  flex-shrink: 0;
}

.song-index.playing {
  color: var(--primary);
}

.index-text {
  font-size: 28rpx;
}

/* 封面 */
.song-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin: 0 24rpx;
  flex-shrink: 0;
}

/* 歌曲信息 */
.song-info {
  flex: 1;
  overflow: hidden;
}

.song-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-name.playing {
  color: var(--primary);
}

.song-artist {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 收藏按钮 */
.song-action {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 分割线 */
.song-item:not(:last-child) .song-info::after {
  content: '';
  display: block;
  height: 1rpx;
  background: var(--border);
  margin-top: 20rpx;
}
