.lyrics-container {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.lyrics-scroll {
  width: 100%;
  height: 100%;
}

.lyrics-list {
  padding: 200rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lyrics-line {
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 20rpx 0;
  transition: all 0.3s ease;
  text-align: center;
  line-height: 1.4;
}

.lyrics-line.active {
  font-size: 36rpx;
  color: var(--primary);
  font-weight: 500;
  transform: scale(1.05);
}

.lyrics-line.empty {
  height: 60rpx;
}
